[Unit]
Description=cyberdeck camera service
After=default.target

[Service]
Type=simple
Restart=always
WorkingDirectory=/home/%u/cyberdeck-camera
ExecStart=/home/%u/cyberdeck/.venv/bin/python /home/%u/cyberdeck/client.py
StandardOutput=journal
StandardError=journal
Environment="PATH=/home/%u/cyberdeck/.venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

[Install]
WantedBy=default.target
